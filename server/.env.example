# ====================================
# Environment Configuration Example
# ====================================
# Copy this file to .env and update the values according to your environment
# DO NOT commit the .env file to version control

# ====================================
# APPLICATION ENVIRONMENT
# ====================================
# Environment: development, production, or test
NODE_ENV=development

# Server port
PORT=9000

# ====================================
# DATABASE CONFIGURATION
# ====================================
# MongoDB connection URI
# Format: mongodb+srv://username:password@cluster.mongodb.net/database-name
# or: mongodb://localhost:27017/database-name
MONGO_URI=mongodb+srv://username:password@cluster0.mongodb.net/blood-app

# ====================================
# JWT TOKEN CONFIGURATION
# ====================================
# JWT Secret Key - Use a strong, random string (min 32 characters recommended)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Access Token Expiration Time (in JWT format)
# Examples: 15m (15 minutes), 1h (1 hour), 7d (7 days)
JWT_ACCESS_EXPIRATION=15m

# Refresh Token Expiration Time (in JWT format)
# Examples: 7d (7 days), 30d (30 days), 90d (90 days)
JWT_REFRESH_EXPIRATION=7d

# ====================================
# CORS CONFIGURATION
# ====================================
# Allowed Origins for CORS
# Examples:
#   - * (allow all - not recommended for production)
#   - http://localhost:3000
#   - https://yourdomain.com
#   - http://localhost:3000,https://yourdomain.com (multiple origins)
CORS_ORIGIN=*

# ====================================
# LOGGING CONFIGURATION (Optional)
# ====================================
# Log level: error, warn, info, debug, verbose
LOG_LEVEL=debug

# ====================================
# EMAIL CONFIGURATION (For future use)
# ====================================
# Email service provider
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-specific-password
# SMTP_FROM=noreply@blood-app.com

# ====================================
# GEOLOCATION CONFIGURATION
# ====================================
# OpenStreetMap Nominatim API (used for location services)
# Note: Uses public API, rate limited to 1 request per second
# For high usage, consider getting an API key from: https://nominatim.openstreetmap.org
# NOMINATIM_API_URL=https://nominatim.openstreetmap.org

# ====================================
# PUSH NOTIFICATION CONFIGURATION (For future use)
# ====================================
# Firebase Cloud Messaging (FCM)
# FCM_SERVER_KEY=your-fcm-server-key
# FCM_SENDER_ID=your-fcm-sender-id

# ====================================
# PAYMENT GATEWAY CONFIGURATION (For future use)
# ====================================
# Stripe Configuration
# STRIPE_SECRET_KEY=sk_test_xxxxx
# STRIPE_PUBLIC_KEY=pk_test_xxxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# ====================================
# ANALYTICS CONFIGURATION (For future use)
# ====================================
# Google Analytics
# GOOGLE_ANALYTICS_ID=UA-xxxxxxxx-x

# ====================================
# SESSION CONFIGURATION
# ====================================
# Session secret for session management
# SESSION_SECRET=your-session-secret-key

# ====================================
# SOCKET.IO CONFIGURATION
# ====================================
# Socket.IO transports
# SOCKET_TRANSPORTS=websocket,polling

# ====================================
# DATABASE CONNECTION POOL (Optional)
# ====================================
# MongoDB connection pool size
# MONGO_POOL_SIZE=10

# ====================================
# RATE LIMITING CONFIGURATION
# ====================================
# Max requests per time window
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=100

# ====================================
# SECURITY CONFIGURATION
# ====================================
# API Key for protected endpoints (if needed)
# API_KEY=your-api-key

# HTTPS settings
# HTTPS_ENABLED=false
# SSL_CERT_PATH=/path/to/cert.pem
# SSL_KEY_PATH=/path/to/key.pem

# ====================================
# EXTERNAL SERVICE ENDPOINTS
# ====================================
# Frontend URL (for email links, redirects, etc.)
# FRONTEND_URL=http://localhost:3000

# ====================================
# DEVELOPMENT-ONLY OPTIONS
# ====================================
# Enable detailed error messages (development only)
# DEBUG=true

# Mock data generation
# SEED_DATABASE=false

# ====================================
# PRODUCTION DEPLOYMENT NOTES
# ====================================
# For production deployment, ensure:
# 1. NODE_ENV=production
# 2. Strong JWT_SECRET (32+ random characters)
# 3. CORS_ORIGIN set to specific frontend domain(s)
# 4. MONGO_URI uses strong credentials and SSL
# 5. All sensitive values encrypted or from secure secret manager
# 6. No debug/verbose logging enabled
# 7. Rate limiting enabled
# 8. HTTPS enabled with valid SSL certificates
